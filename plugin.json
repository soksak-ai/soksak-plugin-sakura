{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-sakura",
  "name": { "en": "Sakura Petals", "ko": "sakura 벚꽃" },
  "version": "1.0.2",
  "repo": "https://github.com/soksak-ai/soksak-plugin-sakura.git",
  "description": { "en": "Cherry blossom petals drift over the app — swaying side to side, tumbling in 3D, and drifting sideways on the breeze. Density, fall speed, and wind are adjustable.", "ko": "앱 위로 벚꽃 잎이 흩날린다 — 좌우로 흔들리며 3D로 텀블해 떨어지고 바람에 옆으로 흐른다. 밀도·낙하속도·바람 조절." },
  "entry": "main.js",
  "permissions": ["ui:overlay:screen", "commands"],
  "contributes": {
    "commands": [
      { "name": "toggle", "title": { "en": "Toggle petals", "ko": "꽃잎 켜기/끄기" } },
      { "name": "density", "title": { "en": "Petal density", "ko": "꽃잎 밀도" } },
      { "name": "fall", "title": { "en": "Fall speed", "ko": "낙하 속도" } },
      { "name": "wind", "title": { "en": "Wind", "ko": "바람" } }
    ]
  }
}
